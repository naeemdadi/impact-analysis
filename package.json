{
  "name": "impact-analysis",
  "version": "1.0.0",
  "description": "Evidence-backed GitHub App for pull request impact analysis",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server/index.ts",
    "start": "node dist/src/server/index.js",
    "test": "tsx --test scripts/*.test.ts",
    "set-ai-assistance": "tsx scripts/set-ai-assistance.ts",
    "reliability:status": "tsx scripts/reliability-status.ts",
    "db:docker:down": "docker compose down",
    "db:docker:init": "./scripts/db-docker-init.sh",
    "db:generate": "pnpm exec drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "pnpm exec drizzle-kit migrate --config=drizzle.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@octokit/app": "^16.1.2",
    "@octokit/webhooks": "^14.2.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "openai": "^6.48.0",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "0.31.10",
    "tsx": "^4.23.1",
    "typescript": "5.9.3"
  }
}
